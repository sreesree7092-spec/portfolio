<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sree Manju | Portfolio</title>

  <style>
    @import url("https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap");

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      scroll-behavior: smooth;
    }

    :root {
      --bg: #070b18;
      --surface: rgba(20, 28, 54, 0.72);
      --purple: #9c6bff;
      --pink: #ff80c8;
      --blue: #54c9ff;
      --text: #f7f7ff;
      --muted: #c2c8da;
    }

    body {
      font-family: "Poppins", sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at 10% 15%, rgba(156, 107, 255, 0.22), transparent 28%),
        radial-gradient(circle at 85% 10%, rgba(84, 201, 255, 0.16), transparent 25%),
        var(--bg);
      overflow-x: hidden;
    }

    /* Animated floating background circles */
    .orb {
      position: fixed;
      border-radius: 50%;
      filter: blur(2px);
      opacity: 0.35;
      z-index: -1;
      animation: float 8s ease-in-out infinite;
    }

    .orb-one {
      width: 170px;
      height: 170px;
      background: var(--purple);
      top: 15%;
      left: -60px;
    }

    .orb-two {
      width: 220px;
      height: 220px;
      background: var(--pink);
      right: -90px;
      bottom: 10%;
      animation-delay: 2s;
    }

    @keyframes float {
      0%, 100% { transform: translateY(0) rotate(0deg); }
      50% { transform: translateY(-35px) rotate(15deg); }
    }

    .container {
      width: min(1120px, 90%);
      margin: auto;
    }

    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(7, 11, 24, 0.82);
      backdrop-filter: blur(15px);
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .nav-content {
      height: 75px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .logo {
      font-size: 1.45rem;
      font-weight: 800;
      background: linear-gradient(90deg, var(--purple), var(--pink));
      -webkit-background-clip: text;
      color: transparent;
    }

    .nav-links {
      display: flex;
      list-style: none;
      gap: 24px;
    }

    .nav-links a {
      color: var(--text);
      text-decoration: none;
      font-size: 0.95rem;
      transition: 0.3s;
    }

    .nav-links a:hover {
      color: var(--pink);
    }

    /* Hero Section */
    .hero {
      min-height: 620px;
      display: grid;
      grid-template-columns: 1fr 1.2fr;
      gap: 70px;
      align-items: center;
      padding: 70px 0;
    }

    .image-3d {
      width: 340px;
      height: 340px;
      margin: auto;
      perspective: 1000px;
      animation: profileEntrance 1.3s ease forwards;
    }

    .image-3d-inner {
      width: 100%;
      height: 100%;
      border-radius: 50%;
      transform-style: preserve-3d;
      animation: rotateProfile 7s ease-in-out infinite;
    }

    .profile-image {
      width: 100%;
      height: 100%;
      border-radius: 50%;
      object-fit: cover;
      border: 6px solid var(--purple);
      box-shadow:
        0 0 25px var(--purple),
        0 0 70px rgba(156, 107, 255, 0.55),
        20px 25px 0 rgba(255, 128, 200, 0.2);
    }

    @keyframes rotateProfile {
      0%, 100% { transform: rotateY(-12deg) rotateX(4deg); }
      50% { transform: rotateY(12deg) rotateX(-4deg); }
    }

    @keyframes profileEntrance {
      from { opacity: 0; transform: translateX(-70px) scale(0.7); }
      to { opacity: 1; transform: translateX(0) scale(1); }
    }

    .hero-text {
      animation: slideUp 1.1s ease forwards;
    }

    @keyframes slideUp {
      from { opacity: 0; transform: translateY(45px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .hero-text h1 {
      font-size: 2rem;
    }

    .hero-text h2 {
      font-size: clamp(3.3rem, 7vw, 5.8rem);
      line-height: 1;
      margin: 12px 0;
      background: linear-gradient(90deg, var(--purple), var(--pink));
      -webkit-background-clip: text;
      color: transparent;
      animation: glowText 2.5s infinite alternate;
    }

    @keyframes glowText {
      from { filter: drop-shadow(0 0 2px var(--purple)); }
      to { filter: drop-shadow(0 0 14px var(--pink)); }
    }

    .hero-text h3 {
      font-size: 1.75rem;
      margin-bottom: 16px;
    }

    .hero-text p {
      color: var(--muted);
      max-width: 560px;
    }

    .btn {
      display: inline-block;
      margin-top: 25px;
      padding: 13px 24px;
      border-radius: 10px;
      color: white;
      text-decoration: none;
      font-weight: 600;
      background: linear-gradient(135deg, var(--purple), var(--pink));
      box-shadow: 0 10px 25px rgba(156, 107, 255, 0.3);
      transition: 0.3s;
    }

    .btn:hover {
      transform: translateY(-5px) scale(1.04);
      box-shadow: 0 15px 35px rgba(255, 128, 200, 0.45);
    }

    section {
      padding: 70px 0;
    }

    .section-title {
      font-size: 2rem;
      margin-bottom: 30px;
      color: var(--purple);
    }

    .grid-two {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 28px;
    }

    /* 3D cards */
    .card, .project-card {
      background: var(--surface);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 18px;
      transition: transform 0.35s ease, box-shadow 0.35s ease;
      transform-style: preserve-3d;
    }

    .card {
      padding: 30px;
    }

    .card:hover, .project-card:hover {
      transform: perspective(900px) rotateX(6deg) rotateY(-6deg) translateY(-10px);
      box-shadow: 15px 20px 30px rgba(0, 0, 0, 0.35);
      border-color: var(--purple);
    }

    .card h3 {
      color: var(--pink);
      margin-bottom: 15px;
      font-size: 1.4rem;
    }

    .card p, .card li {
      color: var(--muted);
    }

    .card ul {
      padding-left: 20px;
    }

    .card li {
      margin: 10px 0;
    }

    /* Skills */
    .skill {
      margin: 20px 0;
    }

    .skill-info {
      display: flex;
      justify-content: space-between;
      margin-bottom: 8px;
    }

    .progress {
      height: 11px;
      background: #27324b;
      border-radius: 20px;
      overflow: hidden;
    }

    .progress span {
      display: block;
      height: 100%;
      border-radius: 20px;
      background: linear-gradient(90deg, var(--purple), var(--pink));
      animation: loadSkill 1.8s ease;
    }

    @keyframes loadSkill {
      from { width: 0 !important; }
    }

    /* Projects */
    .projects {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 25px;
    }

    .project-card {
      padding: 30px 24px;
      text-align: center;
    }

    .project-icon {
      font-size: 3.2rem;
      margin-bottom: 15px;
      animation: iconBounce 2s ease-in-out infinite;
    }

    @keyframes iconBounce {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-9px); }
    }

    .project-card h3 {
      margin-bottom: 12px;
    }

    .project-card p {
      color: var(--muted);
      font-size: 0.94rem;
    }

    footer {
      text-align: center;
      padding: 28px;
      color: var(--muted);
      border-top: 1px solid rgba(255, 255, 255, 0.1);
    }

    @media (max-width: 850px) {
      .hero, .grid-two, .projects {
        grid-template-columns: 1fr;
      }

      .hero {
        text-align: center;
        gap: 35px;
      }

      .hero-text p {
        margin: auto;
      }

      .nav-content {
        height: auto;
        padding: 15px 0;
        flex-direction: column;
        gap: 12px;
      }

      .nav-links {
        flex-wrap: wrap;
        justify-content: center;
        gap: 14px;
      }

      .image-3d {
        width: 260px;
        height: 260px;
      }
    }
  </style>
</head>

<body>
  <div class="orb orb-one"></div>
  <div class="orb orb-two"></div>

  <nav>
    <div class="container nav-content">
      <div class="logo">Sree Manju</div>
      <ul class="nav-links">
        <li><a href="#about">About</a></li>
        <li><a href="#skills">Skills</a></li>
        <li><a href="#internship">Internship</a></li>
        <li><a href="#projects">Projects</a></li>
      </ul>
    </div>
  </nav>

  <main class="container">
    <section class="hero">
      <div class="image-3d">
        <div class="image-3d-inner">
          <img src="profile manju.jpeg" alt="Sree Manju profile photo" class="profile-image">
        </div>
      </div>

      <div class="hero-text">
        <h1>Hello, I'm</h1>
        <h2>Sree Manju</h2>
        <h3>Frontend Developer<br>& Web Designer</h3>
        <p>
          I am a final-year student passionate about frontend development,
          web design, and building responsive digital experiences.
        </p>
        <a href="#projects" class="btn">Explore My Projects</a>
      </div>
    </section>

    <section id="about">
      <div class="grid-two">
        <div class="card">
          <h3>👩‍💻 About Me</h3>
          <p>
            Hello! I am Sree Manju, a frontend developer and web designer.
            I enjoy creating beautiful, responsive, and user-friendly websites.
          </p>
        </div>

        <div class="card">
          <h3>🎓 Education</h3>
          <p><strong>Final Year Student</strong></p>
          <p>Currently pursuing my final-year degree and improving my technical skills.</p>
        </div>
      </div>
    </section>

    <section id="skills">
      <div class="grid-two">
        <div class="card">
          <h3>💻 Technical Skills</h3>

          <div class="skill">
            <div class="skill-info"><span>HTML</span><span>95%</span></div>
            <div class="progress"><span style="width: 95%;"></span></div>
          </div>

          <div class="skill">
            <div class="skill-info"><span>Java</span><span>96%</span></div>
            <div class="progress"><span style="width: 96%;"></span></div>
          </div>

          <div class="skill">
            <div class="skill-info"><span>CSS</span><span>90%</span></div>
            <div class="progress"><span style="width: 90%;"></span></div>
          </div>

          <div class="skill">
            <div class="skill-info"><span>Python</span><span>90%</span></div>
            <div class="progress"><span style="width: 90%;"></span></div>
          </div>
        </div>

        <div class="card" id="internship">
          <h3>💼 Internship Experience</h3>
          <ul>
            <li>App Development</li>
            <li>Full Stack Development</li>
            <li>Web Designing</li>
          </ul>
          <br>
          <p>
            I gained practical experience in application development,
            full-stack development, and designing modern websites.
          </p>
        </div>
      </div>
    </section>

    <section id="projects">
      <h2 class="section-title">📁 My Projects</h2>

      <div class="projects">
        <div class="project-card">
          <div class="project-icon">🖥️</div>
          <h3>Personal Portfolio Website</h3>
          <p>
            A responsive personal portfolio website built with modern HTML,
            CSS, and JavaScript.
          </p>
        </div>

        <div class="project-card">
          <div class="project-icon">📡</div>
          <h3>Arduino-Raspberry Pi Bluetooth Control</h3>
          <p>
            A Bluetooth control system using Arduino and Raspberry Pi for
            smart device applications.
          </p>
        </div>

        <div class="project-card">
          <div class="project-icon">🤖</div>
          <h3>Intelligent Doubt Solving Chatbot</h3>
          <p>
            A chatbot that helps students find answers and solve academic
            doubts efficiently.
          </p>
        </div>
      </div>
    </section>
  </main>

  <footer>
    © 2026 Sree Manju. All rights reserved.
  </footer>
</body>
</html>